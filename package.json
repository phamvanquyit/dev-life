{
  "name": "dev-life",
  "version": "1.0.0",
  "description": "Developer utilities desktop app for macOS",
  "main": "./out/main/index.js",
  "author": "zobite",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "bun run build && electron-builder --dir",
    "build:mac": "bun run build && electron-builder --mac"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.68",
    "@ant-design/cssinjs": "^1.23.0",
    "@ant-design/icons": "^5.6.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.6",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/openai": "^1.4.7",
    "@ricky0123/vad-web": "^0.0.30",
    "ai": "^6.0.197",
    "antd": "^5.24.0",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "mermaid": "^11.15.0",
    "openai": "^6.42.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.17.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.4.0",
    "drizzle-kit": "^0.31.10",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.0",
    "electron-vite": "^3.1.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0"
  },
  "build": {
    "appId": "com.zobite.dev-life",
    "productName": "Dev Life",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns"
    },
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "out/**/*"
    ]
  }
}
